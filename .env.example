OPENROUTER_API_KEY=replace-me
LIVEAVATAR_API_KEY=replace-me
NEXT_PUBLIC_LIVEAVATAR_SANDBOX=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-me
SUPABASE_DB_PASSWORD=replace-me
# Optional if using Supabase's pooler:
# SUPABASE_DB_POOLER_REGION=eu-west-1
# Optional alternative to SUPABASE_DB_PASSWORD:
# SUPABASE_DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
